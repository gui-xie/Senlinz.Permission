<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <IsPackable>false</IsPackable>
    <IsTestProject>false</IsTestProject>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="Microsoft.CodeAnalysis" HintPath="$(MSBuildToolsPath)/Roslyn/bincore/Microsoft.CodeAnalysis.dll" />
    <Reference Include="Microsoft.CodeAnalysis.CSharp" HintPath="$(MSBuildToolsPath)/Roslyn/bincore/Microsoft.CodeAnalysis.CSharp.dll" />
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <Reference Include="Senlinz.Permissions" HintPath="../../src/Senlinz.Permissions/bin/$(Configuration)/net10.0/Senlinz.Permissions.dll" />
    <Reference Include="Senlinz.Permissions.Abstractions" HintPath="../../src/Senlinz.Permissions.Abstractions/bin/$(Configuration)/netstandard2.1/Senlinz.Permissions.Abstractions.dll" />
    <Reference Include="Senlinz.Permissions.AspNetCore" HintPath="../../src/Senlinz.Permissions.AspNetCore/bin/$(Configuration)/net10.0/Senlinz.Permissions.AspNetCore.dll" />
  </ItemGroup>

  <Target Name="BuildReferencedProjects" BeforeTargets="ResolveReferences" Condition="'$(SolutionPath)' == '' or '$(SolutionPath)' == '*Undefined*'">
    <MSBuild Projects="../../src/Senlinz.Permissions.Abstractions/Senlinz.Permissions.Abstractions.csproj;../../src/Senlinz.Permissions/Senlinz.Permissions.csproj;../../src/Senlinz.Permissions.AspNetCore/Senlinz.Permissions.AspNetCore.csproj"
             Targets="Build"
             Properties="Configuration=$(Configuration)" />
  </Target>
</Project>
