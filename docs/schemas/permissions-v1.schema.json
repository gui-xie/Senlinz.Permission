{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.senlinz.dev/permissions/v1.json",
  "title": "Senlinz Permissions v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "permissions"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "const": 1
    },
    "namespace": {
      "type": "string"
    },
    "className": {
      "type": "string"
    },
    "catalogClassName": {
      "type": "string"
    },
    "groups": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/group"
      }
    },
    "permissions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/permission"
      }
    }
  },
  "$defs": {
    "group": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code"],
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(\\.[a-z][a-z0-9]*)*$"
        },
        "name": {
          "type": "string"
        },
        "labelKey": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "descriptionKey": {
          "type": "string"
        },
        "order": {
          "type": "integer"
        }
      }
    },
    "permission": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code"],
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(\\.[a-z][a-z0-9]*)+$"
        },
        "name": {
          "type": "string"
        },
        "group": {
          "type": "string"
        },
        "requires": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9]*(\\.[a-z][a-z0-9]*)+$"
          }
        },
        "description": {
          "type": "string"
        },
        "labelKey": {
          "type": "string"
        },
        "descriptionKey": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "order": {
          "type": "integer"
        }
      }
    }
  }
}
